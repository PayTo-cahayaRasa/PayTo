APP_NAME=PayTo
APP_ENV=local
APP_KEY=
APP_DEBUG=true
APP_URL=http://localhost

# =============================================================================
# PRODUCTION SETTINGS - SET THESE BEFORE DEPLOYING!
# =============================================================================
# APP_ENV=production
# APP_DEBUG=false
# APP_URL=https://yourdomain.com
# =============================================================================

APP_LOCALE=en
APP_FALLBACK_LOCALE=en
APP_FAKER_LOCALE=en_US

APP_MAINTENANCE_DRIVER=file
# APP_MAINTENANCE_STORE=database

# PHP_CLI_SERVER_WORKERS=4

BCRYPT_ROUNDS=12

LOG_CHANNEL=stack
LOG_STACK=single
LOG_DEPRECATIONS_CHANNEL=null
LOG_LEVEL=debug

# =============================================================================
# DATABASE - CONFIGURE FOR YOUR ENVIRONMENT
# =============================================================================
DB_CONNECTION=mysql
DB_HOST=127.0.0.1
DB_PORT=3306
DB_DATABASE=payto
DB_USERNAME=root
DB_PASSWORD=

# =============================================================================
# SESSION SECURITY SETTINGS
# =============================================================================
SESSION_DRIVER=database
SESSION_LIFETIME=120
# IMPORTANT: Set to true in production for encrypted session cookies
SESSION_ENCRYPT=false
SESSION_PATH=/
SESSION_DOMAIN=null
# IMPORTANT: Set to true in production (HTTPS required)
SESSION_SECURE_COOKIE=false
SESSION_HTTP_ONLY=true
SESSION_SAME_SITE=lax

BROADCAST_CONNECTION=log
FILESYSTEM_DISK=local
QUEUE_CONNECTION=database

CACHE_STORE=database
# CACHE_PREFIX=

MEMCACHED_HOST=127.0.0.1

REDIS_CLIENT=phpredis
REDIS_HOST=127.0.0.1
REDIS_PASSWORD=null
REDIS_PORT=6379

MAIL_MAILER=log
MAIL_SCHEME=null
MAIL_HOST=127.0.0.1
MAIL_PORT=2525
MAIL_USERNAME=null
MAIL_PASSWORD=null
MAIL_FROM_ADDRESS="hello@example.com"
MAIL_FROM_NAME="${APP_NAME}"

AWS_ACCESS_KEY_ID=
AWS_SECRET_ACCESS_KEY=
AWS_DEFAULT_REGION=us-east-1
AWS_BUCKET=
AWS_USE_PATH_STYLE_ENDPOINT=false

VITE_APP_NAME="${APP_NAME}"

# =============================================================================
# SECURITY NOTES:
# 1. Generate APP_KEY with: php artisan key:generate
# 2. For production: APP_DEBUG=false, SESSION_ENCRYPT=true, SESSION_SECURE_COOKIE=true
# 3. Use strong DB_PASSWORD in production
# 4. Set APP_URL with HTTPS for production
# =============================================================================
